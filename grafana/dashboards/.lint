exclusions:
  template-datasource-rule:
    reason: "Fixed UID 'claudedog' used by design — Grafana provisioning does not resolve template variables"
  panel-datasource-rule:
    reason: "Same as template-datasource-rule"
  template-job-rule:
    reason: "Not a Prometheus datasource"
  template-instance-rule:
    reason: "Not a Prometheus datasource"
  template-label-promql-rule:
    reason: "Not a Prometheus datasource"
  template-on-time-change-reload-rule:
    reason: "No template variables used"
  target-promql-rule:
    reason: "SQLite datasource, not Prometheus"
  target-rate-interval-rule:
    reason: "SQLite datasource, not Prometheus"
  target-job-rule:
    reason: "SQLite datasource, not Prometheus"
  target-instance-rule:
    reason: "SQLite datasource, not Prometheus"
  target-counter-agg-rule:
    reason: "SQLite datasource, not Prometheus"
  target-logql-rule:
    reason: "SQLite datasource, not Loki"
  target-logql-auto-rule:
    reason: "SQLite datasource, not Loki"
  uneditable-dashboard:
    reason: "Development dashboard — editable for live JSON editing workflow"
